{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "jsx": "react",
    "module": "esnext",
    "moduleResolution": "node",
    "noEmit": false,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "sourceMap": true,
    "target": "esnext",
    "typeRoots": ["./node_modules/@types/",
      "./src/common/typings"
    ],
    "strict": true,
  },
  "include": [
    "./src/common/typings",
    "./src/common/**/*", "./content-script/**/*",
    "./src/extension/popup/**/*"
  ]
}
